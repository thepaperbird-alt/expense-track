rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMonthDocumentId(monthId) {
      return monthId.matches('^\\d{4}-\\d{2}$');
    }

    match /expenseFlowMonths/{monthId} {
      allow read, write: if isSignedIn() && isMonthDocumentId(monthId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
